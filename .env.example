# Flask
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# PostgreSQL (local)
DATABASE_URL=postgresql://postgres:password@localhost:5432/taskflow_dev
TEST_DATABASE_URL=postgresql://postgres:password@localhost:5432/taskflow_test

# AWS S3 (get these from scripts/aws_s3_setup.sh)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=taskflow-api-files
AWS_S3_REGION=us-east-1
